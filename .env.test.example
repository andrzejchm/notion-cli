# Notion Integration Test Environment Variables
# Copy this file to .env.test and fill in real values.
# See docs/testing-setup.md for detailed instructions.

# Internal integration token (starts with ntn_)
NOTION_TEST_TOKEN=ntn_your_integration_token_here

# Root page shared with the integration — contains all fixture pages/databases
NOTION_TEST_ROOT_PAGE_ID=00000000-0000-0000-0000-000000000000

# Page with headings, lists, toggles, callouts, code blocks, table, nested child pages
NOTION_FIXTURE_RICH_PAGE_ID=00000000-0000-0000-0000-000000000000

# Page with title + single paragraph
NOTION_FIXTURE_SIMPLE_PAGE_ID=00000000-0000-0000-0000-000000000000

# Page with title only, no body content
NOTION_FIXTURE_EMPTY_PAGE_ID=00000000-0000-0000-0000-000000000000

# Database with Title, Status, Priority, Due Date, Tags columns and 5-10 rows
NOTION_FIXTURE_TASK_DB_ID=00000000-0000-0000-0000-000000000000

# Same schema as Task Database but with zero rows
NOTION_FIXTURE_EMPTY_DB_ID=00000000-0000-0000-0000-000000000000

# Page with title + paragraph, 2-3 page-level comments and 1 inline comment
NOTION_FIXTURE_COMMENTS_PAGE_ID=00000000-0000-0000-0000-000000000000
